# Application
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
TRUST_PROXY=0
SERVE_STATIC=false

# PostgreSQL
POSTGRES_DB=ai_sales
POSTGRES_USER=ai_sales
POSTGRES_PASSWORD=replace-with-a-random-database-password
DATABASE_URL=postgresql://ai_sales:replace-with-a-random-database-password@localhost:5432/ai_sales?schema=public
# Neon production: pooled DATABASE_URL for the app and unpooled DIRECT_URL for migrations/backups.
DIRECT_URL=
COMPOSE_DATABASE_URL=postgresql://ai_sales:replace-with-a-random-database-password@postgres:5432/ai_sales?schema=public
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000
DATABASE_STATEMENT_TIMEOUT_MS=30000

# Redis (required in production; Compose uses the internal redis hostname)
REDIS_URL=redis://localhost:6379
COMPOSE_REDIS_URL=redis://redis:6379
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_CONNECT_RETRIES=5

# Authentication (replace both with independent random values of at least 32 characters)
JWT_ACCESS_SECRET=replace-with-a-random-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-random-refresh-secret-at-least-32-characters
JWT_ISSUER=ai-sales-platform
JWT_AUDIENCE=ai-sales-platform-web
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
BCRYPT_ROUNDS=12

# Account lifecycle and transactional email (log, smtp, or resend)
APP_BASE_URL=http://localhost:5173
EMAIL_DELIVERY_MODE=log
EMAIL_FROM=no-reply@example.com
EMAIL_REQUEST_TIMEOUT_MS=10000
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com
SMTP_HOST=
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_VERIFICATION_TTL_MINUTES=1440
PASSWORD_RESET_TTL_MINUTES=60
RECOVERY_CODE_COUNT=8

# Browser and request security
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
AI_RATE_LIMIT_WINDOW_MS=3600000
AI_RATE_LIMIT_MAX=20
METRICS_AUTH_TOKEN=replace-with-a-random-metrics-token-at-least-32-characters

# Optional DeepSeek integration. Leave empty to guarantee Mock AI remains cost-free.
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_REQUEST_TIMEOUT_MS=30000
AI_RESPONSE_MAX_BYTES=262144
AI_MAX_TOKENS=1500
# Paid AI remains disabled at 0 even if a key is accidentally present.
AI_MONTHLY_REQUEST_LIMIT=0
AI_HISTORY_RETENTION_DAYS=90
MAINTENANCE_INTERVAL_MS=21600000

# Frontend (use /api for the same-origin production deployment)
VITE_API_URL=/api
